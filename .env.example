# vCenter Server hostname or IP (no scheme).
VCENTER_HOST=vcsa.lab.local

# Optional HTTPS port (defaults to 443).
# VCENTER_PORT=443

# vCenter credentials.
VCENTER_USER=administrator@vsphere.local
VCENTER_PASS=changeme

# Set true to skip TLS certificate verification (homelab/self-signed certs).
# Leave unset or false in production.
VCENTER_INSECURE=false

# Log level: trace | debug | info | warn | error. Defaults to info.
# Logs are written to stderr only; stdout is reserved for JSON-RPC.
VCENTER_LOG_LEVEL=info

# Long-running task polling tunables.
# VCENTER_TASK_TIMEOUT_MS=600000
# VCENTER_TASK_POLL_MS=1500

# Set true to run the MCP in read-only mode regardless of confirm flags.
# VCENTER_READ_ONLY=false
